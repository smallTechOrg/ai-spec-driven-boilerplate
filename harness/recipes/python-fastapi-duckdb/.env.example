# Copy to .env. Defaults run fully offline on SQLite + the stub LLM, no API key.

# App
APPNAME_ENV=development
APPNAME_HOST=127.0.0.1
APPNAME_PORT=8000

# LLM — leave as "stub" to run offline with no API key.
# Switch to "anthropic" and set the key below to go live (install the `llm` extra).
APPNAME_LLM_PROVIDER=stub
APPNAME_LLM_MODEL=claude-sonnet-4-6
APPNAME_ANTHROPIC_API_KEY=

# Database — the relational spine (SQLite via aiosqlite).
APPNAME_DATABASE_URL=sqlite+aiosqlite:///./appname.db

# Data dir — the generic DuckDB columnar store seam (events.duckdb lives here).
APPNAME_DATA_DIR=./data
