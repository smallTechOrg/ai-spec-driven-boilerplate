# BlogGen environment variables
# Copy this file to .env and fill in your values.
# All variables use the BLOGGEN_ prefix.

# PostgreSQL connection string (required)
BLOGGEN_DATABASE_URL=postgresql+psycopg2://user:password@localhost:5432/bloggen

# Google Gemini API key (required for real article generation; leave empty for stub mode)
BLOGGEN_GEMINI_API_KEY=

# LLM model to use (optional; default: gemini-2.0-flash)
BLOGGEN_LLM_MODEL=gemini-2.0-flash

# Log level (optional; default: INFO)
BLOGGEN_LOG_LEVEL=INFO
