# Copy to .env. Defaults run fully offline on SQLite with the stub LLM.

# App
APPNAME_ENV=development
APPNAME_PORT=8001

# LLM — leave as "stub" to run offline with no API key.
# Switch to openai | anthropic | gemini and set the matching key to go live.
APPNAME_LLM_PROVIDER=stub
APPNAME_LLM_MODEL=
APPNAME_OPENAI_API_KEY=
APPNAME_ANTHROPIC_API_KEY=
APPNAME_GEMINI_API_KEY=

# Database — local-first relational store (SQLite via aiosqlite).
APPNAME_DATABASE_URL=sqlite+aiosqlite:///./app.db
