# DataChat — private, single-user CSV/Excel analysis agent.
# Copy to .env and fill in AGENT_GEMINI_API_KEY. This is the only manual setup step.

AGENT_DATABASE_URL=sqlite:///./data/agent.db

# LLM provider — DataChat uses Gemini.
# Auto-detected from whichever key is set below; Anthropic remains an optional fallback.
# AGENT_LLM_PROVIDER=gemini

# Model id (uses the Gemini default — gemini-2.5-flash — when blank):
# AGENT_LLM_MODEL=gemini-2.5-flash

# Required: your Gemini API key.
AGENT_GEMINI_API_KEY=
# Optional fallback provider key:
AGENT_ANTHROPIC_API_KEY=

PORT=8001
