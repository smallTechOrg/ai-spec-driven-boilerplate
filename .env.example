# Food Tracker — environment variables
# Copy this file to .env and fill in the values.
# All variables are prefixed with FOOD_TRACKER_

# --- Required ---
# PostgreSQL connection string (must start with postgresql://)
FOOD_TRACKER_DATABASE_URL=postgresql://localhost/food_tracker

# --- Optional ---
# Google Gemini API key. When set, the app uses real Gemini Vision.
# When absent, the app runs in stub/demo mode (no API call made).
FOOD_TRACKER_GEMINI_API_KEY=

# Gemini model name (default: gemini-2.0-flash)
FOOD_TRACKER_LLM_MODEL=gemini-2.0-flash

# Dev server port (default: 8001)
FOOD_TRACKER_PORT=8001

# --- Test database ---
# Used by conftest.py when running pytest. Must be a separate DB from dev.
TEST_DATABASE_URL=postgresql://localhost/food_tracker_test

