# Sourcing Agent — environment variables
# Copy to .env and fill in.
# All vars are prefixed SOURCING_.

# --- Database (required) ---
SOURCING_DATABASE_URL=postgresql+psycopg2://localhost:5432/sourcing
# Separate DB for tests (must already exist locally)
SOURCING_TEST_DATABASE_URL=postgresql+psycopg2://localhost:5432/sourcing_test

# --- LLM (Gemini) ---
# When SOURCING_GEMINI_API_KEY is set, provider auto-resolves to "gemini".
# When unset, provider auto-resolves to "stub" (UI shows a stub banner).
SOURCING_GEMINI_API_KEY=
SOURCING_LLM_MODEL=gemini-2.0-flash
SOURCING_LLM_PROVIDER=auto    # auto | gemini | stub

# --- Web search (Tavily) ---
# When SOURCING_TAVILY_API_KEY is set, search auto-resolves to "tavily".
# When unset, search auto-resolves to "stub" (returns canned suppliers).
SOURCING_TAVILY_API_KEY=
SOURCING_SEARCH_PROVIDER=auto # auto | tavily | stub

# --- App ---
SOURCING_LOG_LEVEL=INFO
SOURCING_HOST=127.0.0.1
SOURCING_PORT=8000
