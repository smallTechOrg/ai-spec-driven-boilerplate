# EU Lead Gen Agent — environment variables
# Copy this file to .env and fill in the values

# Database
LGA_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/lead_gen_agent
LGA_TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/lead_gen_agent_test

# LLM
LGA_GEMINI_API_KEY=your-gemini-api-key-here
LGA_LLM_MODEL=gemini-2.5-flash
# auto = use real Gemini when key is set, stub otherwise
LGA_LLM_PROVIDER=auto

# App
LGA_LOG_LEVEL=INFO
PORT=8001
