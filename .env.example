AGENT_DATABASE_URL=sqlite:///./data/agent.db

# LLM provider — Gemini for the Local Data Analyst (auto-detected from the key).
# Override explicitly: anthropic | gemini
# AGENT_LLM_PROVIDER=gemini

# Model — defaults to gemini-2.5-flash (low cost tier) when blank.
# AGENT_LLM_MODEL=gemini-2.5-flash

# Provider key — set the Gemini key (Anthropic is unused for this project):
AGENT_GEMINI_API_KEY=
AGENT_ANTHROPIC_API_KEY=

# Where uploaded source files + DuckDB caches are stored (local only):
# AGENT_DATA_DIR=./data/datasets
# Max upload size in bytes (~100 MB default):
# AGENT_MAX_UPLOAD_BYTES=104857600

PORT=8001
