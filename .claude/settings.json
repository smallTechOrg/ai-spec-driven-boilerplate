{
  "permissions": {
    "allow": [
      "Edit",
      "Write",
      "Read",
      "Bash(*)"
    ],
    "deny": []
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/push-after-commit.sh"
          }
        ]
      }
    ]
  }
}
