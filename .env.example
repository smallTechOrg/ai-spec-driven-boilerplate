# Data Analyst Agent — Environment Variables
# Copy this file to .env and fill in the required values.
# .env is gitignored — never commit real keys.
#
# All commands run from the repo root (where this file lives).

# --- LLM Provider (required) ---
# GEMINI_API_KEY is required. Tests and the full app call the real Gemini API.
# Set: DA_GEMINI_API_KEY=your-key-here
DA_GEMINI_API_KEY=

# LLM model to use (binding: gemini-2.0-flash, fall back to gemini-2.5-flash if not available)
DA_LLM_MODEL=gemini-2.0-flash

# --- Database ---
# SQLite database for sessions, dataset catalogue, and audit log.
# Default: data/data_analyst.db (relative to repo root)
DA_DATABASE_URL=sqlite:///data/data_analyst.db

# --- DuckDB ---
# In-process DuckDB database file for query execution.
# Default: data/duckdb.db
DA_DUCKDB_PATH=data/duckdb.db

# --- File Uploads ---
# Directory where uploaded CSV/Excel files are stored.
# Default: data/uploads
DA_UPLOAD_DIR=data/uploads

# --- Server ---
DA_PORT=8001
DA_LOG_LEVEL=INFO

# --- Token Economy ---
# Number of recent conversation turns to keep in context before summarising.
DA_MAX_HISTORY_TURNS=20
# Number of recent turns to retain after summarisation.
DA_SUMMARY_KEEP_TURNS=6

# --- Agent ---
# Maximum number of tool-call rounds per chat turn (safety limit).
DA_MAX_TOOL_ROUNDS=10

# --- Env Forwarding (do not change) ---
# The following are read directly (no DA_ prefix) for compatibility:
GEMINI_API_KEY=
LLM_PROVIDER=gemini
LLM_MODEL=gemini-2.0-flash
