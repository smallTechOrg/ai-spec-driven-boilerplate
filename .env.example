# Lead Gen Agent — environment variables
# Copy to .env and fill in.

# Postgres — tests use a separate DB
LEADGEN_DATABASE_URL=postgresql+psycopg2://sai@localhost:5432/lead_gen_agent
# For running pytest, point DATABASE_URL at the _test database:
# LEADGEN_DATABASE_URL=postgresql+psycopg2://sai@localhost:5432/lead_gen_agent_test

# LLM
# provider=auto resolves to 'gemini' when GEMINI_API_KEY is set, else 'stub'
LEADGEN_LLM_PROVIDER=auto
LEADGEN_LLM_MODEL=gemini-2.5-flash
GEMINI_API_KEY=

# Web server
PORT=8001
