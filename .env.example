# Data Analyst Agent — environment variables
# Copy this file to .env and fill in real values before running.

# SQLite database path (local, fully offline)
AGENT_DATABASE_URL=sqlite:///./data/agent.db

# Gemini API key — required (get from https://aistudio.google.com/app/apikey)
AGENT_GEMINI_API_KEY=

# Optional: override the default model (gemini-2.5-flash)
# AGENT_LLM_MODEL=gemini-2.5-flash

# Dev server port
PORT=8001
