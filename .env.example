# BlogForge
BLOGFORGE_DATABASE_URL=postgresql+psycopg2://sai@localhost:5432/blogforge
BLOGFORGE_TEST_DATABASE_URL=postgresql+psycopg2://sai@localhost:5432/blogforge_test

# LLM — set the key and you're done. Provider defaults to "auto": gemini when a
# key is present, stub otherwise. Force a provider by setting BLOGFORGE_LLM_PROVIDER.
BLOGFORGE_GEMINI_API_KEY=
BLOGFORGE_LLM_MODEL=gemini-2.5-flash
# BLOGFORGE_LLM_PROVIDER=auto   # auto | gemini | stub

BLOGFORGE_LOG_LEVEL=INFO
PORT=8001
