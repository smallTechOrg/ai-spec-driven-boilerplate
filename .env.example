# DataChat — local personal data-analysis agent
# Copy to .env and fill in your Gemini API key. .env is gitignored.

# App's own metadata store (SQLite — local personal tool, NOT the analysed data)
AGENT_DATABASE_URL=sqlite:///./data/agent.db

# LLM provider — auto-detected from whichever key is set below.
# DataChat uses Gemini 2.5 Flash (low cost, frugal calls).
# Override explicitly if needed: anthropic | gemini
# AGENT_LLM_PROVIDER=gemini

# Override model (uses provider default when blank):
# DataChat default is gemini-2.5-flash.
# AGENT_LLM_MODEL=gemini-2.5-flash

# Set your Gemini key (required for DataChat):
AGENT_GEMINI_API_KEY=
# Optional alternative provider:
AGENT_ANTHROPIC_API_KEY=

PORT=8001
