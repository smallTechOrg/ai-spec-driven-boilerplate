# Data Analysis Agent — Environment Variables
# Copy to .env and fill in your values

# ── Database ────────────────────────────────────────────────────────────────
# SQLite database file path
DATAANALYSIS_DATABASE_URL=sqlite:///data_analysis.db

# ── LLM ─────────────────────────────────────────────────────────────────────
# Google Gemini API key — leave blank or unset for stub mode
DATAANALYSIS_GEMINI_API_KEY=

# LLM model name
DATAANALYSIS_LLM_MODEL=gemini-2.5-flash

# ── App ──────────────────────────────────────────────────────────────────────
PORT=8001
DATAANALYSIS_LOG_LEVEL=INFO
