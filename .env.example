# Sourcing Agent — environment variables
# Copy this file to .env and fill in the values.
# All commands run from the repo root (where pyproject.toml lives).

# ── Database ──────────────────────────────────────────────────────────────────
SA_DATABASE_URL=postgresql://user@localhost:5432/sourcing
SA_TEST_DATABASE_URL=postgresql://user@localhost:5432/sourcing_test

# ── LLM (Google Gemini) ───────────────────────────────────────────────────────
# Set SA_GEMINI_API_KEY to enable real AI sourcing.
# Leave blank to run in stub mode (results are simulated).
SA_GEMINI_API_KEY=
SA_LLM_MODEL=gemini-2.5-flash
# auto = real when key is set, stub otherwise
SA_LLM_PROVIDER=auto

# ── Scoring weights (must sum to 1.0) ────────────────────────────────────────
SA_WEIGHT_PRICE=0.40
SA_WEIGHT_LEAD_TIME=0.35
SA_WEIGHT_CERTS=0.25

# ── App ───────────────────────────────────────────────────────────────────────
SA_LOG_LEVEL=INFO
PORT=8001
