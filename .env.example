# Data Analysis Agent — environment variables
# Copy this file to .env and fill in values. Never commit .env.

# Database — SQLite (local file)
AGENT_DATABASE_URL=sqlite:///./data/agent.db

# LLM provider — auto-detected from whichever key is set below.
# Override explicitly: anthropic | gemini
# AGENT_LLM_PROVIDER=gemini

# Default model for this project:
AGENT_LLM_MODEL=gemini-2.0-flash

# Set exactly ONE provider key:
AGENT_ANTHROPIC_API_KEY=
AGENT_GEMINI_API_KEY=your_gemini_api_key_here

# Model routing (optional) — map a logical task to a model id. Blank → provider default.
# AGENT_MODEL_CLASSIFY=gemini-2.0-flash
# AGENT_MODEL_TOOLS=gemini-2.0-flash
# AGENT_MODEL_REASON=gemini-2.0-flash

# Dev server port (default 8001)
PORT=8001
