# BlogForge environment variables
# Copy to .env and fill in your values

GEMINI_API_KEY=your-gemini-api-key-here
TAVILY_API_KEY=your-tavily-api-key-here   # optional — topic discovery works without it

DATABASE_URL=sqlite+aiosqlite:///./data/blogforge.db
IMAGES_DIR=./images
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO
