AGENT_DATABASE_URL=sqlite:///./data/agent.db

# LLM provider — auto-detected from whichever key is set below.
# Override explicitly: anthropic | gemini
# AGENT_LLM_PROVIDER=anthropic

# Override model (uses provider default when blank):
# AGENT_LLM_MODEL=claude-sonnet-4-6   (Anthropic default)
# AGENT_LLM_MODEL=gemini-2.5-flash     (Gemini default)

# Set exactly ONE provider key (Gemini gemini-2.5-flash is the configured default):
AGENT_ANTHROPIC_API_KEY=
AGENT_GEMINI_API_KEY=

# Data-analysis agent settings (optional — sensible defaults shown):
# AGENT_DATA_DIR=./data          # uploaded CSVs + sqlite db live here
# AGENT_MAX_STEPS=4              # agentic-loop step cap before reporting failure
# AGENT_SAMPLE_ROWS=20          # bounded row sample sent to the LLM (privacy boundary)

PORT=8001
