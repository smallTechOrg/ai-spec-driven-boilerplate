# Copy to `.env` and fill in APP_LLM_API_KEY with your funded key. `.env` is gitignored — never commit it.
# A real run (and `make gate`) REQUIRES a funded APP_LLM_API_KEY.

APP_LLM_PROVIDER=anthropic
APP_LLM_MODEL=claude-haiku-4-5
APP_LLM_API_KEY=

# Optional overrides (defaults shown):
# APP_DATABASE_URL=sqlite+aiosqlite:///./agent.db
# APP_PORT=8001
# APP_MAX_ITERATIONS=6
